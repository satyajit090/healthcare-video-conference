# Copy this file to ".env" and adjust as needed. All values have sane defaults
# for local development, so you can also just run `docker compose up` without a .env.

# --- Database ---
DB_NAME=healthconnect
DB_USER=healthconnect
DB_PASSWORD=healthconnect

# --- RabbitMQ ---
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- Security ---
# Use a long random string (256-bit+) in production.
JWT_SECRET=change-this-in-prod-a-very-long-256-bit-secret-key-0123456789abcdef

# Origins allowed to call the API (the frontend is served at :8088 by default).
CORS_ORIGINS=http://localhost:8088,http://localhost:5173

# --- Gemini AI (optional) ---
# Leave blank to run without AI. The app degrades gracefully and shows a
# placeholder instead of AI output when no key is set.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
